  <script nonce="<%= nonce %>">
  function togglePeachPanel(e) {
    if (e) e.stopPropagation();
    const p = document.getElementById('peach-panel');
    const visible = getComputedStyle(p).display !== 'none';
    p.style.display = visible ? 'none' : 'block';
  }
  const peachBubble = document.getElementById('peach-bubble');
  if (peachBubble) {
    peachBubble.addEventListener('click', togglePeachPanel);
    peachBubble.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); togglePeachPanel(); }
    });
  }
  document.addEventListener('click', function(e) {
    if (!e.target.closest('#peach-bubble') && !e.target.closest('#peach-panel')) {
      document.getElementById('peach-panel').style.display = 'none';
    }
  });
  </script>

